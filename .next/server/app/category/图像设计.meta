{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/category/layout,_N_T_/category/[name]/layout,_N_T_/category/[name]/page,_N_T_/category/%E5%9B%BE%E5%83%8F%E8%AE%BE%E8%AE%A1"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/category/$d$name/__PAGE__",
    "/category/$d$name",
    "/category",
    "/_index",
    "/_head"
  ]
}